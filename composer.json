{
    "name": "directorytree/privacy-filter",
    "description": "Laravel wrapper for privacy-filter.cpp binaries.",
    "license": "MIT",
    "type": "library",
    "require": {
        "directorytree/privacy-filter-classifier": "dev-master",
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "DirectoryTree\\PrivacyFilter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DirectoryTree\\PrivacyFilter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DirectoryTree\\PrivacyFilter\\PrivacyFilterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/DirectoryTree/PrivacyFilterClassifier"
        }
    ],
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    }
}
